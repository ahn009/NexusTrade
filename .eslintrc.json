{
  "root": true,
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "env": {
    "node": true,
    "es2022": true,
    "browser": true,
    "jest": true
  },
  "extends": ["next/core-web-vitals"],
  "settings": {
    "next": {
      "rootDir": "apps/frontend/"
    }
  },
  "rules": {
    "@next/next/no-html-link-for-pages": "off"
  },
  "ignorePatterns": ["dist", "node_modules", ".next", "services/matching-engine/target"]
}

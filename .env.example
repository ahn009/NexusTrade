# .env.example
NODE_ENV=development
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=nexus
DATABASE_PASSWORD=nexus
DATABASE_NAME=nexus
DATABASE_SSL=false
SQLITE_DATABASE=:memory:
JWT_SECRET=replace-with-strong-secret
SERVICE_AUTH_TOKEN=replace-with-internal-service-token
API_KEY_SECRET=replace-with-api-key-secret
CORS_ORIGINS=http://localhost:3020
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nexustrade-service
KAFKA_DLQ_TOPIC=nexus.dlq
REDIS_URL=redis://localhost:6379
MATCHING_ENGINE_GRPC_URL=localhost:50051
MATCHING_ENGINE_SNAPSHOT_PATH=matching-engine.snapshot.json
AUTH_SERVICE_URL=http://localhost:3001
USER_SERVICE_URL=http://localhost:3002
TRADING_SERVICE_URL=http://localhost:3003
WALLET_SERVICE_URL=http://localhost:3004
MARKET_DATA_SERVICE_URL=http://localhost:3005
RISK_SERVICE_URL=http://localhost:3006
DEPOSIT_SERVICE_URL=http://localhost:3007
WITHDRAWAL_SERVICE_URL=http://localhost:3008
COMPLIANCE_SERVICE_URL=http://localhost:3009
NOTIFICATION_SERVICE_URL=http://localhost:3010
MAKER_FEE_BPS=2
TAKER_FEE_BPS=4
MIN_DEPOSIT_AMOUNT=0.00000001
WITHDRAWAL_TOTP_REQUIRED=true
WITHDRAWAL_WHITELIST_COOLDOWN_MS=86400000
COMPLIANCE_WATCHLIST=blocked-address,sanctioned-entity
EMAIL_PROVIDER=log
SMS_PROVIDER=log
PUSH_PROVIDER=log
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v3
